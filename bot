<script>
// ==========================================
//  STATE
// ==========================================
let ws = null;
let authorized = false;
let botRunning = false;
let inTrade = false;
let ticksData = [];
let currentDigit = -1;
let previousDigit = -1;
let currentStake = 1.00;
let baseStake = 1.00;
let consecutiveLosses = 0;
let consecutiveWins = 0;
let wins = 0, losses = 0, pnl = 0, totalTrades = 0;
let balance = 0;
let currency = 'USD';
let authToken = null;
let logEntries = [];
let currentSymbol = 'R_10';
let pairIndex = 0;
let activeTab = 'dtrader';
let freeBotActive = null;
let copyActive = null;
let copyTimer = null;
let freeBotTimer = null;
let reconnectAttempts = 0;
let keepAliveInterval = null;
let pingInterval = null;

const VOL_PAIRS = ['R_10', 'R_25', 'R_50', 'R_75', 'R_100'];
const PAIR_INFO = {
  'R_10': { badge: '10', name: 'Volatility 10 Index', label: 'V10' },
  'R_25': { badge: '25', name: 'Volatility 25 Index', label: 'V25' },
  'R_50': { badge: '50', name: 'Volatility 50 Index', label: 'V50' },
  'R_75': { badge: '75', name: 'Volatility 75 Index', label: 'V75' },
  'R_100': { badge: '100', name: 'Volatility 100 Index', label: 'V100' }
};
const WINDOW = 100;
const TOKEN_KEY = 'u7api_token';
const APP_ID_KEY = 'u7api_appid';
const DEFAULT_APP_ID = '1089';
let APP_ID = DEFAULT_APP_ID;

// ==========================================
//  TABS
// ==========================================
function switchTab(tab) {
  activeTab = tab;
  document.querySelectorAll('.nav-tab').forEach(t => t.classList.remove('active'));
  event.currentTarget.classList.add('active');
  document.getElementById('tab-trader').style.display = tab === 'trader' ? 'block' : 'none';
  document.getElementById('tab-freebots').style.display = tab === 'freebots' ? 'block' : 'none';
  document.getElementById('tab-dtrader').style.display = tab === 'dtrader' ? 'block' : 'none';
  document.getElementById('tab-copy').style.display = tab === 'copy' ? 'block' : 'none';
}

// ==========================================
//  STARTUP — HANDLE OAUTH CALLBACK
// ==========================================
window.onload = () => {
  initGrid();

  // Load saved App ID
  const savedAppId = localStorage.getItem(APP_ID_KEY);
  if (savedAppId) {
    APP_ID = savedAppId;
    document.getElementById('appIdInput').value = savedAppId;
  }

  // Check if we just came back from Deriv OAuth (URL has #token1=...)
  const hash = window.location.hash;
  if (hash && hash.includes('token1=')) {
    parseOAuthCallback(hash);
    return;
  }

  // Check for saved manual token
  const savedToken = localStorage.getItem(TOKEN_KEY);
  if (savedToken) {
    document.getElementById('tokenInput').value = savedToken;
  }
};

function parseOAuthCallback(hash) {
  // Deriv returns tokens in URL hash: #token1=abc&token2=def&...
  const params = new URLSearchParams(hash.replace('#', ''));
  const tokens = [];
  let i = 1;
  while (params.has('token' + i)) {
    tokens.push(params.get('token' + i));
    i++;
  }

  if (tokens.length > 0) {
    authToken = tokens[0];
    // Save token for future auto-login
    localStorage.setItem(TOKEN_KEY, authToken);

    // Clean URL so refresh doesn't re-trigger
    history.replaceState(null, null, window.location.pathname + window.location.search);

    // Show dashboard and connect
    document.getElementById('loginOverlay').classList.add('hidden');
    document.getElementById('mainDash').style.display = 'block';
    connect(authToken);
    return;
  }

  // If no token found in hash, show error
  setStatus('⚠ OAuth login failed. No token received.');
}

function saveAppId() {
  const id = document.getElementById('appIdInput').value.trim();
  if (!id || isNaN(id)) { setStatus('⚠ Enter a valid numeric App ID'); return; }
  APP_ID = id;
  localStorage.setItem(APP_ID_KEY, id);
  setStatus('✓ App ID saved');
  setTimeout(() => setStatus(''), 2000);
}

function loginWithDeriv() {
  const id = document.getElementById('appIdInput').value.trim();
  if (!id || isNaN(id)) { setStatus('⚠ Enter your App ID first'); return; }
  APP_ID = id;
  localStorage.setItem(APP_ID_KEY, id);

  // Build OAuth URL — Deriv sends user back to this exact page after login
  const redirectUri = encodeURIComponent(window.location.href.split('#')[0]);
  const oauthUrl = `https://oauth.deriv.com/oauth2/authorize?app_id=${APP_ID}&l=EN&brand=deriv&redirect_uri=${redirectUri}`;
  window.location.href = oauthUrl;
}

function doConnectManual() {
  const token = document.getElementById('tokenInput').value.trim();
  if (!token) { setStatus('⚠ Paste your API token first'); return; }
  authToken = token;
  if (document.getElementById('rememberMe').checked) localStorage.setItem(TOKEN_KEY, token);
  setStatus('Connecting to Deriv...');
  connect(token);
}

function setStatus(msg) { document.getElementById('loginStatus').textContent = msg; }

function disconnect() {
  if (ws) { ws.close(); ws = null; }
  authorized = false; botRunning = false; inTrade = false;
  freeBotActive = null; copyActive = null;
  if (copyTimer) clearInterval(copyTimer);
  if (freeBotTimer) clearInterval(freeBotTimer);
  if (keepAliveInterval) clearInterval(keepAliveInterval);
  if (pingInterval) clearInterval(pingInterval);
  authToken = null; currentSymbol = 'R_10'; pairIndex = 0; ticksData = [];
  reconnectAttempts = 0;
  document.getElementById('mainDash').style.display = 'none';
  document.getElementById('loginOverlay').classList.remove('hidden');
  setStatus('');
  // Clear saved token so next visit requires login
  localStorage.removeItem(TOKEN_KEY);
}

// ==========================================
//  WEBSOCKET — FIXED CONNECTION & RECONNECT
// ==========================================
function connect(token) {
  if (ws) { try { ws.close(); } catch(e){} ws = null; }

  ws = new WebSocket(`wss://ws.derivws.com/websockets/v3?app_id=${APP_ID}`);

  ws.onopen = () => {
    reconnectAttempts = 0;
    sendMsg({ authorize: token });
    // Start keepalive ping every 20s to prevent timeout
    if (pingInterval) clearInterval(pingInterval);
    pingInterval = setInterval(() => {
      if (ws && ws.readyState === WebSocket.OPEN) {
        sendMsg({ ping: 1 });
      }
    }, 20000);
  };

  ws.onmessage = (e) => {
    try { route(JSON.parse(e.data)); } catch(err) { console.error('Parse error', err); }
  };

  ws.onerror = (err) => {
    console.error('WS Error:', err);
    setStatus('⚠ Connection error. Retrying...');
  };

  ws.onclose = () => {
    document.getElementById('connDot').className = 'conn-dot';
    if (pingInterval) clearInterval(pingInterval);
    if (keepAliveInterval) clearInterval(keepAliveInterval);

    if (authToken) {
      reconnectAttempts++;
      const delay = Math.min(3000 * reconnectAttempts, 30000); // Exponential backoff, max 30s
      setBotMode('RECONNECTING...');
      setTimeout(() => {
        if (authToken) connect(authToken);
      }, delay);
    }
  };
}

function sendMsg(obj) {
  if (ws && ws.readyState === WebSocket.OPEN) {
    ws.send(JSON.stringify(obj));
  }
}

function route(d) {
  if (!d || !d.msg_type) return;

  if (d.error) {
    if (d.msg_type === 'authorize') {
      setStatus('⚠ ' + d.error.message);
      authorized = false;
    }
    if (d.msg_type === 'buy') {
      inTrade = false;
      addLog('-', 'BUY FAIL: ' + d.error.message, 'loss');
    }
    return;
  }

  const h = {
    authorize: onAuth,
    balance: onBalance,
    history: onHistory,
    tick: onTick,
    buy: onBuy,
    proposal_open_contract: onContractUpdate,
    ping: () => {} // keepalive response, ignore
  };
  if (h[d.msg_type]) h[d.msg_type](d[d.msg_type] || d);
}

// ==========================================
//  HANDLERS
// ==========================================
function onAuth(a) {
  if (!a || a.error) {
    setStatus('⚠ Authorization failed');
    authorized = false;
    return;
  }
  authorized = true;
  currency = a.currency || 'USD';
  balance = parseFloat(a.balance) || 0;
  document.getElementById('connDot').className = 'conn-dot live';
  document.getElementById('balanceDisplay').textContent = balance.toFixed(2) + ' ' + currency;
  document.getElementById('loginOverlay').classList.add('hidden');
  document.getElementById('mainDash').style.display = 'block';
  updateAssetDisplay(); updatePairChips();
  sendMsg({ balance: 1, subscribe: 1 });
  // Request history + subscribe to ticks
  sendMsg({ ticks_history: currentSymbol, adjust_start_time: 1, count: WINDOW, end: 'latest', start: 1, style: 'ticks', subscribe: 1 });
  addLog('-', 'Connected · ' + PAIR_INFO[currentSymbol].label, 'pending');
}

function onBalance(b) {
  if (!b) return;
  balance = parseFloat(b.balance);
  document.getElementById('balanceDisplay').textContent = balance.toFixed(2) + ' ' + (b.currency || currency);
}

function onHistory(h) {
  if (!h || !h.prices) return;
  ticksData = h.prices.map(p => lastDigit(p));
  renderAll();
}

function onTick(t) {
  if (!t || t.symbol !== currentSymbol) return;
  const price = t.quote;
  const digit = lastDigit(price);
  previousDigit = currentDigit;
  currentDigit = digit;
  ticksData.push(digit);
  if (ticksData.length > WINDOW) ticksData.shift();
  document.getElementById('assetPrice').innerHTML = parseFloat(price).toFixed(2) + ' <span class="price-up">▲</span>';
  document.getElementById('curDigitDisplay').textContent = digit;
  document.getElementById('lastDigitLabel').textContent = 'Last: ' + digit;
  document.getElementById('sampleCount').textContent = ticksData.length;
  renderAll();
  if (botRunning && !inTrade && ticksData.length >= 20) evalAndTrade();
}

function onBuy(b) {
  if (!b) return;
  addLog(b.contract_id, PAIR_INFO[currentSymbol].label + ' UNDER 7 · ' + currentStake.toFixed(2) + ' USD', 'pending');
  sendMsg({ proposal_open_contract: 1, contract_id: b.contract_id, subscribe: 1 });
}

function onContractUpdate(c) {
  if (!c || c.status === 'open') return;
  inTrade = false;
  totalTrades++;
  const profit = parseFloat(c.profit) || 0;
  if (profit > 0) {
    wins++; pnl += profit; consecutiveLosses = 0; consecutiveWins++; currentStake = baseStake;
    updateLog(c.contract_id, 'WIN +' + profit.toFixed(2), 'win');
    if (consecutiveWins >= 3) { consecutiveWins = 0; switchPair('3 wins streak'); }
  } else {
    losses++; pnl -= currentStake; consecutiveLosses++; consecutiveWins = 0; applyMartingale();
    updateLog(c.contract_id, 'LOSS -' + currentStake.toFixed(2), 'loss');
    if (consecutiveLosses >= 2) { consecutiveLosses = 0; currentStake = baseStake; document.getElementById('stakeInput').value = baseStake.toFixed(2); switchPair('2 losses streak'); }
  }
  updateStats();
}

// ==========================================
//  MANUAL TRADER TAB
// ==========================================
let mWins = 0, mLosses = 0, mPnl = 0, mInTrade = false;

function manualTrader(side) {
  if (!authorized) { alert('Not connected'); return; }
  const stake = parseFloat(document.getElementById('manualStake').value) || 1;
  mInTrade = true;
  sendMsg({
    buy: 1, price: stake,
    parameters: { amount: stake, basis: 'stake', contract_type: side === 'under' ? 'DIGITUNDER' : 'DIGITOVER', currency: currency, duration: 1, duration_unit: 't', symbol: currentSymbol, barrier: '7' }
  });
}

// ==========================================
//  FREE BOTS TAB
// ==========================================
function startFreeBot(type) {
  if (!authorized) { alert('Not connected'); return; }
  freeBotActive = type;
  addFreeBotLog('🤖 ' + type.toUpperCase() + ' BOT STARTED');
  freeBotTimer = setInterval(() => runFreeBotLogic(type), 2000);
}

function stopFreeBot(type) {
  freeBotActive = null;
  if (freeBotTimer) clearInterval(freeBotTimer);
  addFreeBotLog('■ ' + type.toUpperCase() + ' BOT STOPPED');
}

function runFreeBotLogic(type) {
  if (inTrade || !ticksData.length) return;
  const freq = getFreq();
  const digit = currentDigit;
  if (type === 'differ') {
    if (freq[digit] > 15) {
      sendMsg({ buy: 1, price: 1, parameters: { amount: 1, basis: 'stake', contract_type: 'DIGITDIFF', currency: currency, duration: 1, duration_unit: 't', symbol: currentSymbol, barrier: String(digit) } });
      addFreeBotLog('DIGIT DIFFER on ' + digit);
    }
  } else if (type === 'evenodd') {
    const evenCount = [0,2,4,6,8].reduce((s,d)=>s+freq[d],0);
    const oddCount = [1,3,5,7,9].reduce((s,d)=>s+freq[d],0);
    const side = evenCount > oddCount ? 'DIGITODD' : 'DIGITEVEN';
    sendMsg({ buy: 1, price: 1, parameters: { amount: 1, basis: 'stake', contract_type: side, currency: currency, duration: 1, duration_unit: 't', symbol: currentSymbol } });
    addFreeBotLog((side==='DIGITEVEN'?'EVEN':'ODD') + ' SIGNAL');
  } else if (type === 'matches') {
    if (digit >= 5) {
      sendMsg({ buy: 1, price: 0.5, parameters: { amount: 0.5, basis: 'stake', contract_type: 'DIGITMATCH', currency: currency, duration: 1, duration_unit: 't', symbol: currentSymbol, barrier: String(digit) } });
      addFreeBotLog('MATCH on ' + digit);
    }
  } else if (type === 'flip') {
    const bias = [0,1,2,3,4].reduce((s,d)=>s+freq[d],0) > 50 ? 'DIGITOVER' : 'DIGITUNDER';
    sendMsg({ buy: 1, price: 1, parameters: { amount: 1, basis: 'stake', contract_type: bias, currency: currency, duration: 1, duration_unit: 't', symbol: currentSymbol, barrier: '5' } });
    addFreeBotLog('FLIP ' + (bias==='DIGITOVER'?'OVER':'UNDER') + ' 5');
  }
}

function addFreeBotLog(msg) {
  const wrap = document.getElementById('freeBotLog');
  const time = new Date().toLocaleTimeString();
  const html = `<div class="log-row"><span class="log-time">${time}</span><span class="log-desc">${msg}</span><span class="log-pending">BOT</span></div>`;
  if (wrap.querySelector('.log-empty')) wrap.innerHTML = html;
  else wrap.insertAdjacentHTML('afterbegin', html);
}

// ==========================================
//  COPY TRADING TAB
// ==========================================
function copyTrader(id) {
  if (!authorized) { alert('Not connected'); return; }
  copyActive = id;
  addCopyLog('📋 COPYING ' + id.toUpperCase());
  copyTimer = setInterval(() => {
    if (Math.random() > 0.3 && !inTrade) {
      const stake = parseFloat(document.getElementById('stakeInput').value) || 1;
      const side = Math.random() > 0.5 ? 'DIGITUNDER' : 'DIGITOVER';
      sendMsg({ buy: 1, price: stake, parameters: { amount: stake, basis: 'stake', contract_type: side, currency: currency, duration: 1, duration_unit: 't', symbol: currentSymbol, barrier: '7' } });
      addCopyLog(id.toUpperCase() + ' → ' + (side==='DIGITUNDER'?'UNDER':'OVER') + ' 7');
    }
  }, 3500);
}

function stopCopy(id) {
  copyActive = null;
  if (copyTimer) clearInterval(copyTimer);
  addCopyLog('✕ STOPPED COPYING ' + id.toUpperCase());
}

function addCopyLog(msg) {
  const wrap = document.getElementById('copyLog');
  const time = new Date().toLocaleTimeString();
  const html = `<div class="log-row"><span class="log-time">${time}</span><span class="log-desc">${msg}</span><span class="log-pending">COPY</span></div>`;
  if (wrap.querySelector('.log-empty')) wrap.innerHTML = html;
  else wrap.insertAdjacentHTML('afterbegin', html);
}

// ==========================================
//  PAIR SWITCHER — FIXED forget_all
// ==========================================
function manualSwitch(sym) {
  if (inTrade) return;
  // Proper forget_all: send array of strings
  sendMsg({ forget_all: ['ticks', 'history'] });
  currentSymbol = sym; pairIndex = VOL_PAIRS.indexOf(sym);
  ticksData = []; previousDigit = -1; currentDigit = -1;
  updateAssetDisplay(); updatePairChips();
  sendMsg({ ticks_history: currentSymbol, adjust_start_time: 1, count: WINDOW, end: 'latest', start: 1, style: 'ticks', subscribe: 1 });
  addLog('-', '→ ' + PAIR_INFO[currentSymbol].label + ' (manual)', 'pending');
}

function switchPair(reason) {
  sendMsg({ forget_all: ['ticks', 'history'] });
  pairIndex = (pairIndex + 1) % VOL_PAIRS.length;
  currentSymbol = VOL_PAIRS[pairIndex];
  ticksData = []; previousDigit = -1; currentDigit = -1;
  updateAssetDisplay(); updatePairChips();
  sendMsg({ ticks_history: currentSymbol, adjust_start_time: 1, count: WINDOW, end: 'latest', start: 1, style: 'ticks', subscribe: 1 });
  addLog('-', '→ ' + PAIR_INFO[currentSymbol].label + ' (' + reason + ')', 'pending');
}

function updateAssetDisplay() {
  const info = PAIR_INFO[currentSymbol];
  document.getElementById('assetBadge').textContent = info.badge;
  document.getElementById('assetName').textContent = info.name;
}

function updatePairChips() {
  VOL_PAIRS.forEach(sym => {
    const chip = document.getElementById('chip_' + sym);
    if (sym === currentSymbol) chip.classList.add('active');
    else chip.classList.remove('active');
  });
}

// ==========================================
//  MARTINGALE
// ==========================================
function applyMartingale() {
  const multi = parseFloat(document.getElementById('martMulti').value) || 1;
  if (multi > 1) { currentStake = parseFloat((currentStake * multi).toFixed(2)); document.getElementById('stakeInput').value = currentStake.toFixed(2); }
}

function onStakeChange() {
  baseStake = parseFloat(document.getElementById('stakeInput').value) || 1;
  currentStake = baseStake; consecutiveLosses = 0;
  updatePayouts();
}

// ==========================================
//  STRATEGY LOGIC
// ==========================================
function lastDigit(price) { const s = parseFloat(price).toFixed(2).replace('.', ''); return parseInt(s[s.length - 1]); }
function getFreq() { const c = Array(10).fill(0); ticksData.forEach(d => c[d]++); const n = ticksData.length || 1; return c.map(x => (x / n) * 100); }

function checkConditions(freq) {
  const c1 = [6,7,8,9].every(d => freq[d] < 10);
  const c2 = [0,1,2,3,4].some(d => freq[d] > 10);
  const c3 = previousDigit >= 0 && previousDigit <= 4 && freq[previousDigit] > 10;
  const c4 = currentDigit === 8 || currentDigit === 9;
  const met = [c1, c2, c3, c4].filter(Boolean).length;
  return { c1, c2, c3, c4, entry: met >= 3, met };
}

function evalAndTrade() {
  const freq = getFreq();
  const { entry } = checkConditions(freq);
  if (entry) placeTrade();
}

function placeTrade() {
  const stake = currentStake;
  if (stake < 0.35) currentStake = 0.35;
  inTrade = true;
  sendMsg({ buy: 1, price: currentStake, parameters: { amount: currentStake, basis: 'stake', contract_type: 'DIGITUNDER', currency: currency, duration: 1, duration_unit: 't', symbol: currentSymbol, barrier: '7' } });
}

function manualTrade(side) {
  if (!authorized) { alert('Not connected'); return; }
  const stake = parseFloat(document.getElementById('stakeInput').value) || 1;
  inTrade = true;
  sendMsg({ buy: 1, price: stake, parameters: { amount: stake, basis: 'stake', contract_type: side === 'under' ? 'DIGITUNDER' : 'DIGITOVER', currency: currency, duration: 1, duration_unit: 't', symbol: currentSymbol, barrier: '7' } });
}

// ==========================================
//  BOT CONTROLS
// ==========================================
function startBot() {
  if (!authorized) { alert('Not connected'); return; }
  baseStake = parseFloat(document.getElementById('stakeInput').value) || 1;
  currentStake = baseStake; botRunning = true; inTrade = false;
  consecutiveLosses = 0; consecutiveWins = 0;
  document.getElementById('btnStart').disabled = true;
  document.getElementById('btnStop').disabled = false;
  document.getElementById('botDot').className = 'bot-status-dot on';
  setBotMode('SCANNING...');
}

function stopBot() {
  botRunning = false; inTrade = false;
  document.getElementById('btnStart').disabled = false;
  document.getElementById('btnStop').disabled = true;
  document.getElementById('botDot').className = 'bot-status-dot';
  setBotMode('IDLE');
  document.getElementById('signalBar').className = 'signal-bar';
  document.getElementById('signalBar').textContent = '⏳ BOT STOPPED';
}

function setBotMode(m) { document.getElementById('botModeLabel').textContent = m; }

// ==========================================
//  UI RENDERING
// ==========================================
function renderAll() {
  const freq = getFreq();
  renderGrid(freq);
  updateConditions(freq);
  updatePayouts();
}

function renderGrid(freq) {
  const { c3, c4 } = ticksData.length >= 10 ? checkConditions(freq) : { c3:false, c4:false };
  function circle(d, f) {
    let cls = '';
    const isCurr = d === currentDigit;
    if (isCurr && (d===8||d===9) && c4 && c3) cls = 's-entry';
    else if (isCurr) cls = 's-active';
    else if (d <= 4 && f > 10) cls = 's-hi04';
    else if (d >= 6 && f >= 10) cls = 's-bad69';
    else if (d >= 6 && f >= 7) cls = 's-ok69';
    return `<div class="digit-circle ${cls}"><span class="d-num">${d}</span><span class="d-pct">${f.toFixed(1)}%</span></div>`;
  }
  document.getElementById('row04').innerHTML = [0,1,2,3,4].map(d => circle(d, freq[d])).join('');
  document.getElementById('row59').innerHTML = [5,6,7,8,9].map(d => circle(d, freq[d])).join('');
}

function updateConditions(freq) {
  if (ticksData.length < 10) return;
  const { c1, c2, c3, c4, entry } = checkConditions(freq);
  function setC(id, ok) { const el = document.getElementById(id); el.textContent = ok ? '✓ YES' : '✗ NO'; el.className = 'cond-card-val ' + (ok ? 'cond-ok' : 'cond-no'); }
  setC('cond1', c1); setC('cond2', c2); setC('cond3', c3); setC('cond4', c4);
  const bar = document.getElementById('signalBar');
  if (entry) { bar.className = 'signal-bar entry-now'; bar.textContent = '🎯 SIGNAL! ENTERING UNDER 7 NOW!'; setBotMode('EXECUTING TRADE...'); }
  else { bar.className = 'signal-bar'; const met = [c1,c2,c3,c4].filter(Boolean).length; bar.textContent = `⏳ WAITING... ${met}/4 CONDITIONS MET`; if (botRunning) setBotMode('SCANNING...'); }
}

function updatePayouts() {
  const stake = parseFloat(document.getElementById('stakeInput').value) || 1;
  document.getElementById('payoutOver').textContent = (stake * 1.95).toFixed(2);
  document.getElementById('payoutUnder').textContent = (stake * 4.00).toFixed(2);
}

function updateStats() {
  document.getElementById('statWins').textContent = wins;
  document.getElementById('statLosses').textContent = losses;
  const pnlEl = document.getElementById('statPnl');
  pnlEl.textContent = (pnl >= 0 ? '+' : '') + pnl.toFixed(2);
  pnlEl.style.color = pnl >= 0 ? '#2e7d32' : '#b71c1c';
  document.getElementById('statTrades').textContent = totalTrades;
}

// ==========================================
//  TRADE LOG
// ==========================================
function addLog(id, msg, type) {
  logEntries.unshift({ id: String(id), msg, type, time: new Date().toLocaleTimeString() });
  if (logEntries.length > 30) logEntries.pop();
  renderLog();
}

function updateLog(id, msg, type) {
  const e = logEntries.find(x => x.id === String(id));
  if (e) { e.msg = msg; e.type = type; }
  renderLog();
}

function renderLog() {
  const wrap = document.getElementById('logWrap');
  if (!logEntries.length) { wrap.innerHTML = '<div class="log-empty">No trades yet</div>'; return; }
  wrap.innerHTML = logEntries.map(e => `<div class="log-row"><span class="log-time">${e.time}</span><span class="log-desc">${e.msg}</span><span class="log-${e.type}">${e.type.toUpperCase()}</span></div>`).join('');
}

function initGrid() {
  const empty = d => `<div class="digit-circle"><span class="d-num">${d}</span><span class="d-pct">-.-%</span></div>`;
  document.getElementById('row04').innerHTML = [0,1,2,3,4].map(empty).join('');
  document.getElementById('row59').innerHTML = [5,6,7,8,9].map(empty).join('');
}
</script>
